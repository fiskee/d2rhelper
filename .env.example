# Copy this to .env and add your Gemini API key
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here
# Optional override (defaults to gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Path to Diablo II: Resurrected installation directory (optional, auto-detected if not set)
# D2R_PATH=/path/to/Diablo II Resurrected
